From 5594ead5d069d20f88f2ab519583a9297d1c9c37 Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Tue, 17 Mar 2026 09:20:18 +0100
Subject: [PATCH] Adapt for OpenTelemetry 1.25

---
 .../internal/operation_context_factory.cc      | 16 +++++++++++-----
 google/cloud/opentelemetry/CMakeLists.txt      |  2 ++
 .../internal/monitored_resource.cc             |  2 +-
 .../cloud/opentelemetry/internal/recordable.cc |  2 +-
 .../opentelemetry/internal/time_series.cc      | 18 ++++++++++--------
 5 files changed, 25 insertions(+), 15 deletions(-)

diff --git a/google/cloud/bigtable/internal/operation_context_factory.cc b/google/cloud/bigtable/internal/operation_context_factory.cc
index 39f45fdc..45e645f3 100644
--- a/google/cloud/bigtable/internal/operation_context_factory.cc
+++ b/google/cloud/bigtable/internal/operation_context_factory.cc
@@ -23,6 +23,7 @@
 #include "absl/strings/str_split.h"
 #include "google/api/monitored_resource.pb.h"
 #include <opentelemetry/context/runtime_context.h>
+#include <opentelemetry/nostd/variant.h>
 #include <opentelemetry/sdk/metrics/export/periodic_exporting_metric_reader.h>
 #include <opentelemetry/sdk/metrics/export/periodic_exporting_metric_reader_factory.h>
 #include <opentelemetry/sdk/metrics/meter_context_factory.h>
@@ -214,15 +215,20 @@ void MetricsOperationContextFactory::InitializeProvider(
         auto& labels = *resource.mutable_labels();
         auto const& attributes = pda.attributes.GetAttributes();
         labels[kProjectLabel] =
-            std::get<std::string>(attributes.find(kProjectLabel)->second);
+            opentelemetry::nostd::get<std::string>(
+                attributes.find(kProjectLabel)->second);
         labels[kInstanceLabel] =
-            std::get<std::string>(attributes.find(kInstanceLabel)->second);
+            opentelemetry::nostd::get<std::string>(
+                attributes.find(kInstanceLabel)->second);
         labels[kTableLabel] =
-            std::get<std::string>(attributes.find(kTableLabel)->second);
+            opentelemetry::nostd::get<std::string>(
+                attributes.find(kTableLabel)->second);
         labels[kClusterLabel] =
-            std::get<std::string>(attributes.find(kClusterLabel)->second);
+            opentelemetry::nostd::get<std::string>(
+                attributes.find(kClusterLabel)->second);
         labels[kZoneLabel] =
-            std::get<std::string>(attributes.find(kZoneLabel)->second);
+            opentelemetry::nostd::get<std::string>(
+                attributes.find(kZoneLabel)->second);
         return std::make_pair(labels[kProjectLabel], resource);
       };
 
diff --git a/google/cloud/opentelemetry/CMakeLists.txt b/google/cloud/opentelemetry/CMakeLists.txt
index 72275c51..3d99260e 100644
--- a/google/cloud/opentelemetry/CMakeLists.txt
+++ b/google/cloud/opentelemetry/CMakeLists.txt
@@ -15,6 +15,8 @@
 # ~~~
 
 find_package(opentelemetry-cpp CONFIG REQUIRED)
+include(GoogleCloudCppCommon)
+include(CMakePackageConfigHelpers)
 
 set(DOXYGEN_PROJECT_NAME "C++ OpenTelemetry Exporters for Google Cloud")
 set(DOXYGEN_PROJECT_BRIEF
diff --git a/google/cloud/opentelemetry/internal/monitored_resource.cc b/google/cloud/opentelemetry/internal/monitored_resource.cc
index 3e5c09c8..e9da1ead 100644
--- a/google/cloud/opentelemetry/internal/monitored_resource.cc
+++ b/google/cloud/opentelemetry/internal/monitored_resource.cc
@@ -236,7 +236,7 @@ MonitoredResourceProvider MakeProvider(
 
 std::string AsString(
     opentelemetry::sdk::common::OwnedAttributeValue const& attribute) {
-  return std::visit(AsStringVisitor{}, attribute);
+  return opentelemetry::nostd::visit(AsStringVisitor{}, attribute);
 }
 
 MonitoredResource ToMonitoredResource(
diff --git a/google/cloud/opentelemetry/internal/recordable.cc b/google/cloud/opentelemetry/internal/recordable.cc
index 89ed90d8..e7febb15 100644
--- a/google/cloud/opentelemetry/internal/recordable.cc
+++ b/google/cloud/opentelemetry/internal/recordable.cc
@@ -208,7 +208,7 @@ void AddAttributeImpl(
     std::size_t limit) {
   auto* proto = ProtoOrDrop(attributes, key, limit);
   if (proto) {
-    std::visit(AttributeVisitor{*proto}, value);
+    opentelemetry::nostd::visit(AttributeVisitor{*proto}, value);
   } else {
     attributes.set_dropped_attributes_count(
         attributes.dropped_attributes_count() + 1);
diff --git a/google/cloud/opentelemetry/internal/time_series.cc b/google/cloud/opentelemetry/internal/time_series.cc
index b5077c3f..9673a39a 100644
--- a/google/cloud/opentelemetry/internal/time_series.cc
+++ b/google/cloud/opentelemetry/internal/time_series.cc
@@ -22,7 +22,7 @@
 #include <opentelemetry/sdk/metrics/export/metric_producer.h>
 #include <opentelemetry/semconv/incubating/service_attributes.h>
 #include <cctype>
-#include <variant>
+#include <opentelemetry/nostd/variant.h>
 
 namespace google {
 namespace cloud {
@@ -41,10 +41,10 @@ google::protobuf::Timestamp ToProtoTimestamp(
 google::monitoring::v3::TypedValue ToValue(
     opentelemetry::sdk::metrics::ValueType value) {
   google::monitoring::v3::TypedValue proto;
-  if (std::holds_alternative<double>(value)) {
-    proto.set_double_value(std::get<double>(value));
+  if (opentelemetry::nostd::holds_alternative<double>(value)) {
+    proto.set_double_value(opentelemetry::nostd::get<double>(value));
   } else {
-    proto.set_int64_value(std::get<std::int64_t>(value));
+    proto.set_int64_value(opentelemetry::nostd::get<std::int64_t>(value));
   }
   return proto;
 }
@@ -63,9 +63,10 @@ google::api::MetricDescriptor::ValueType ToValueType(
 }
 
 double AsDouble(opentelemetry::sdk::metrics::ValueType const& v) {
-  return std::holds_alternative<double>(v)
-             ? std::get<double>(v)
-             : static_cast<double>(std::get<std::int64_t>(v));
+  return opentelemetry::nostd::holds_alternative<double>(v)
+             ? opentelemetry::nostd::get<double>(v)
+             : static_cast<double>(
+                   opentelemetry::nostd::get<std::int64_t>(v));
 }
 
 std::vector<google::monitoring::v3::CreateTimeSeriesRequest> ToRequestsHelper(
@@ -127,7 +128,8 @@ void ToTimeSeriesHelper(
             return absl::nullopt;
           }
         };
-        auto ts = std::visit(Visitor{metric_data}, pda.point_data);
+        auto ts =
+            opentelemetry::nostd::visit(Visitor{metric_data}, pda.point_data);
         if (!ts) continue;
         ts->set_unit(metric_data.instrument_descriptor.unit_);
         ts_collector_fn(metric_data, pda, *std::move(ts));
